<?xml version="1.0" encoding="utf-8"?>
?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pure white background (matches your splash) -->
    <item android:drawable="@android:color/white" />

    <!-- Optional: Add your logo centered here if you want it BEFORE Flutter loads -->
    <!-- Remove these lines if you don't want a native splash logo -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>